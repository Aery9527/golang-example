{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "LS",
      "Edit",
      "MultiEdit",
      "Write",
      "Task",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git stash *)",
      "Bash(git checkout *)",
      "Bash(npm run *)",
      "Bash(npm test)",
      "Bash(npm install *)",
      "Bash(npx *)",
      "WebFetch",
      "WebSearch",
      "Bash(echo \"EXIT:$?\")",
      "Bash(go build:*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(git push *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Read(.env*)",
      "Read(**/secrets/**)",
      "Edit(.env*)",
      "Write(.env*)"
    ]
  }
}
